{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Strict type checking — enables strictNullChecks, noImplicitAny,
       strictFunctionTypes, strictBindCallApply, strictPropertyInitialization,
       noImplicitThis, alwaysStrict, and useUnknownInCatchVariables */
    "strict": true,

    /* Additional strictness beyond the 'strict' flag */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,

    /* Index-access safety: arr[i] returns T | undefined instead of T */
    "noUncheckedIndexedAccess": true,

    /* Disallow dot-notation on index-signature types (must use bracket notation) */
    "noPropertyAccessFromIndexSignature": true,

    /* Optional properties cannot be explicitly assigned undefined;
       only genuine absence (omission) is allowed */
    "exactOptionalPropertyTypes": true,

    "erasableSyntaxOnly": true
  },
  "include": ["src", "env.ts"]
}
